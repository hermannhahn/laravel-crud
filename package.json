{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "setup": "cp .env.example .env && composer install && npm install && ./vendor/bin/sail up -d && sleep 10 && ./vendor/bin/sail artisan key:generate && ./vendor/bin/sail artisan migrate && npm run build",
        "start": "./vendor/bin/sail up -d",
        "stop": "./vendor/bin/sail stop",
        "build": "vue-tsc && vite build && vite build --ssr",
        "dev": "vite",
        "migrate": "./vendor/bin/sail artisan migrate"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^5.0.0",
        "@vue/server-renderer": "^3.4.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.2.1",
        "typescript": "^5.6.3",
        "vite": "^7.0.7",
        "vue": "^3.4.0",
        "vue-tsc": "^2.0.24"
    },
    "dependencies": {
        "@types/lodash": "^4.17.24",
        "chart.js": "^4.5.1",
        "lodash": "^4.17.23",
        "vue-chartjs": "^5.3.3"
    }
}
